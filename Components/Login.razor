@page "/login"
@using Q5.Services
@inject AuthenticationStateService AuthService
@implements IDisposable

@rendermode InteractiveServer

<div class="card shadow-sm m-4" style="max-width: 400px; border-radius: 12px;">
    <div class="card-body text-center p-4">
        <h3 class="card-title mb-4 fw-bold text-secondary">Account Portal</h3>

        <div class="mb-4">
            Status:
            @if (AuthService.IsAuthenticated)
            {
                <span class="badge bg-success fs-6">Active Session</span>
            }
            else
            {
                <span class="badge bg-danger fs-6">Logged Out</span>
            }
        </div>

        @if (!AuthService.IsAuthenticated)
        {
            <button class="btn btn-primary btn-lg w-100 shadow" @onclick="AuthService.LogIn">
                <i class="bi bi-box-arrow-in-right me-2"></i> Log In
            </button>
        }
        else
        {
            <button class="btn btn-outline-danger btn-lg w-100 shadow-sm" @onclick="AuthService.LogOut">
                <i class="bi bi-box-arrow-left me-2"></i> Log Out
            </button>
        }
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}