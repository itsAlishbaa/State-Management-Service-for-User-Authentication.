@page "/profile"
@using Q5.Services
@inject AuthenticationStateService AuthService
@implements IDisposable

@rendermode InteractiveServer

<div class="container mt-4">
    <div class="row">
        <div class="col-md-6">
            @if (AuthService.IsAuthenticated)
            {
                <div class="alert alert-success d-flex align-items-center p-4 shadow-sm border-0" role="alert" style="border-radius: 15px;">
                    <div class="me-3 fs-1">
                        🚀
                    </div>
                    <div>
                        <h4 class="alert-heading fw-bold mb-1">Welcome Back, User!</h4>
                        <p class="mb-0 text-muted">You have successfully bypassed the matrix. Enjoy your secure dashboard.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning d-flex align-items-center p-4 shadow-sm border-0" role="alert" style="border-radius: 15px;">
                    <div class="me-3 fs-1">
                        🔒
                    </div>
                    <div>
                        <h4 class="alert-heading fw-bold mb-1">Access Restricted</h4>
                        <p class="mb-0 text-muted">Please head over to the <a href="/login" class="alert-link text-decoration-underline">Login Page</a> to authenticate yourself.</p>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}