@page "/"
@using Q5.Services
@inject AuthenticationStateService AuthService
@implements IDisposable

@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="container py-5 text-center">
    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm border">
        <div class="container-fluid py-5">
            <h1 class="display-5 fw-bold text-dark mb-3">Welcome to Blazor State Management</h1>
            <p class="col-md-8 mx-auto fs-5 text-muted">
                This app demonstrates how a shared Singleton service instantly syncs user authentication across different independent pages.
            </p>

            <hr class="my-4 mx-auto" style="max-width: 300px;" />

            <div class="mb-4">
                <span class="fs-6 text-uppercase fw-bold tracking-wider text-muted d-block mb-2">Current System State</span>
                @if (AuthService.IsAuthenticated)
                {
                    <span class="badge bg-success p-3 fs-6 rounded-pill shadow-sm">
                        <i class="bi bi-shield-check me-2"></i>User Session Authenticated
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary p-3 fs-6 rounded-pill shadow-sm">
                        <i class="bi bi-shield-lock me-2"></i>Anonymous / Public Access
                    </span>
                }
            </div>

            <div class="d-grid gap-2 d-sm-flex justify-content-sm-center mt-4">
                <a href="/login" class="btn btn-primary btn-lg px-4 gap-3 shadow">
                    <i class="bi bi-person-fill-gear me-2"></i>Go to Portal
                </a>
                <a href="/profile" class="btn btn-outline-secondary btn-lg px-4">
                    <i class="bi bi-person-bounding-box me-2"></i>View Profile
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        AuthService.OnChange -= StateHasChanged;
    }
}