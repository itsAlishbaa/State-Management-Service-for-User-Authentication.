@page "/"
@using BlazorAuthDemo.Services
@inject AuthenticationStateService AuthService
@implements IDisposable

<PageTitle>Home</PageTitle>

<div class="container d-flex justify-content-center align-items-center" style="min-height: 70vh;">
    <div class="card p-5 shadow-sm text-center border-0 bg-white style-card" style="max-width: 600px; width: 100%; border-radius: 16px;">
        
        <div class="d-flex justify-content-center align-items-center mb-4 gap-2">
            @if (AuthService.IsAuthenticated)
            {
                <div class="d-inline-flex align-items-center px-3 py-1 bg-success-subtle text-success border border-success-subtle rounded-pill small fw-semibold">
                    <span class="bg-success rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                    Logged In
                </div>
            }
            else
            {
                <div class="d-inline-flex align-items-center px-3 py-1 bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill small fw-semibold">
                    <span class="bg-secondary rounded-circle me-2" style="width: 8px; height: 8px;"></span>
                    Logged Out
                </div>
            }
        </div>

        <h1 class="fw-bold text-dark mb-3 h2">Welcome to App Dashboard</h1>
        <p class="text-muted mb-4 px-3 fs-6">
            Manage your account profile, check your current session details, and test out our internal real-time application state synchronization.
        </p>

        <div class="d-flex gap-3 justify-content-center pt-2">
            <a href="/login" class="btn btn-primary px-4 py-2 fw-medium shadow-sm" style="border-radius: 8px;">
                Manage Session
            </a>
            <a href="/profile" class="btn btn-outline-secondary px-4 py-2 fw-medium" style="border-radius: 8px;">
                View Profile
            </a>
        </div>
    </div>
</div>