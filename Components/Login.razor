@page "/auth-gate"
@inject AuthenticationStateService AuthService
@implements IDisposable
@attribute [RenderModeInteractiveServer]

<div class="dashboard-viewport">
    <div class="premium-dark-card">
        <div class="card-header">
            <h2>Security Terminal</h2>
            <p>Simulate instant server-side authorization handshake</p>
        </div>

        <div class="display-metric-box">
            <span class="metric-label">System Gateway</span>
            @if (AuthService.IsAuthenticated)
            {
                <h3 class="status-badge status-online">ACCESS GRANTED</h3>
            }
            else
            {
                <h3 class="status-badge status-offline">LOCKED OUT</h3>
            }
        </div>

        <div class="action-grid">
            @if (!AuthService.IsAuthenticated)
            {
                <button class="action-btn-main btn-glow-purple" @onclick="AuthService.LogIn">
                    Initialize Log In
                </button>
            }
            else
            {
                <button class="action-btn-main btn-glow-red" @onclick="AuthService.LogOut">
                    Kill Session (Log Out)
                </button>
            }
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        AuthService.OnStateChanged += InvokeAsyncStateHasChanged;
    }

    private void InvokeAsyncStateHasChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        AuthService.OnStateChanged -= InvokeAsyncStateHasChanged;
    }
}